{
  "name": "spinning-board-game",
  "version": "1.0.0",
  "description": "A spinning board game on Stacks blockchain (Mainnet)",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "clarinet test",
    "play": "node scripts/play-game.js play",
    "wallets:generate": "node scripts/play-game.js generate --count 50",
    "wallets:play:dry": "node scripts/play-game.js play --wallets generated/mainnet-wallets.json --count 10 --spin random --dry-run",
    "wallets:play": "node scripts/play-game.js play --wallets generated/mainnet-wallets.json --count 10 --spin random",
    "wallets:fund:dry": "node scripts/fund-wallets.js --wallets generated/mainnet-wallets.json --count 50 --dry-run",
    "wallets:fund": "node scripts/fund-wallets.js --wallets generated/mainnet-wallets.json --count 50"
  },
  "keywords": [
    "stacks",
    "blockchain",
    "game",
    "clarity",
    "mainnet"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@stacks/connect": "^8.2.4",
    "@stacks/network": "^6.17.0",
    "@stacks/transactions": "^6.17.0",
    "@stacks/wallet-sdk": "^7.2.0"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  }
}
